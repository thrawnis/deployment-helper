# ── Deployment Dashboard — environment config ─────────────────────────────
#
# Copy this file to .env and fill in your projects.
# Projects are numbered sequentially starting at 1.
# Add as many as you need; stop when the next number is absent.

# Project 1
PROJECT_1_NAME=Money Tracker
PROJECT_1_PATH=/home/user/money-tracker
PROJECT_1_SCRIPT=./rebuild.sh

# Project 2
PROJECT_2_NAME=Other App
PROJECT_2_PATH=/home/user/other-app
PROJECT_2_SCRIPT=./rebuild.sh

# Project 3 — example with a custom script
# PROJECT_3_NAME=API Server
# PROJECT_3_PATH=/home/user/api-server
# PROJECT_3_SCRIPT=./deploy.sh
